{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {

    "status": {
      "type": "enumeration",
      "enum": ["draft", "pending", "approved", "rejected"],
      "default": "draft"
    },
    "listingType": {
      "type": "string",
      "required": true,
      "default": "SALE"
    },
    "categoryType": {
      "type": "string",
      "required": true,
      "default": "GOODS"
    },
    "conditionType": {
      "type": "string",
      "default": "NEW"
    },
    "nation": {
      "type": "string"
    },
    "province": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "goodsAddress": {
      "type": "text"
    },
    "geographicScope": {
      "type": "string"
    },
    "priceReviewTime": {
      "type": "string",
      "description": "HH:mm"
    },
    "timeLive": {
      "type": "datetime"
    },
    "endPostDate": {
      "type": "datetime"
    },
    "shape": {
      "type": "string"
    },
    "custom_id": {
      "type": "string"
    },
    "personInCharge": {
      "type": "string"
    },
    "phoneNumber": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "displayPrice": {
      "type": "boolean",
      "default": true
    },
    "hidePrice": {
      "type": "boolean",
      "default": false
    },
    "confirmOwnership": {
      "type": "boolean",
      "default": false
    },

    "items": {
      "type": "json",
      "description": "Per-row product grid data (name, model, size, warranty, pricing, delivery, payment…)"
    },

    "successFee": {
      "type": "decimal",
      "min": 0
    },
    "eventPercentFee": {
      "type": "decimal",
      "min": 0
    },
    "eventFee": {
      "type": "decimal",
      "min": 0
    },
    "mainPageViewCount": {
      "type": "integer",
      "min": 0
    },
    "videoFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["videos"]
    },
    "livestreamPercentFee": {
      "type": "decimal",
      "min": 0
    },
    "livestreamFee": {
      "type": "decimal",
      "min": 0
    },
    "livestreamNote": {
      "type": "string"
    },
    "livestreamVideoFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["videos"]
    },
    "livestreamCertFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },
    "advertisingPercent": {
      "type": "decimal",
      "min": 0
    },
    "advertisingFee": {
      "type": "decimal",
      "min": 0
    },
    "advertisingAmount": {
      "type": "decimal",
      "min": 0
    },
    "advertisingVideoFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["videos"]
    },
    "advertisingCertFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },

    "regLivestreamGoods": { "type": "boolean", "default": false },
    "regLivestreamGoodsPercent": { "type": "decimal", "min": 0 },
    "regLivestreamGoodsFee": { "type": "decimal", "min": 0 },
    "regLivestreamGoodsAI": { "type": "boolean", "default": false },
    "regLivestreamGoodsPerson": { "type": "boolean", "default": false },
    "regLivestreamProductProfile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },
    "regLivestreamCertFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },

    "regProductAdVideo": { "type": "boolean", "default": false },
    "regProductAdPercent": { "type": "decimal", "min": 0 },
    "regProductAdFee": { "type": "decimal", "min": 0 },
    "regProductAdAI": { "type": "boolean", "default": false },
    "regProductAdPerson": { "type": "boolean", "default": false },
    "regProductAdPlatformSupport": { "type": "boolean", "default": false },
    "regProductAdCompanyProfile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },
    "regProductAdCertFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },

    "regPersonalBrandVideo": { "type": "boolean", "default": false },
    "regPersonalBrandPercent": { "type": "decimal", "min": 0 },
    "regPersonalBrandFee": { "type": "decimal", "min": 0 },
    "regPersonalBrandAI": { "type": "boolean", "default": false },
    "regPersonalBrandPerson": { "type": "boolean", "default": false },
    "regPersonalBrandProductProfile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },
    "regPersonalBrandCertFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    },

    "totalFees": {
      "type": "decimal",
      "min": 0
    },

    "poster": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
